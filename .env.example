# ── Database ───────────────────────────────────────────────────────────────

# (A) LOCAL DEV — SQLite, zero install (default). Just run `npm run db:setup`.
DATABASE_URL="file:./dev.db"

# (B) PRODUCTION / 1000+ concurrent — PostgreSQL.
#   1. In prisma/schema.prisma set: provider = "postgresql"
#   2. Use a POOLED connection string (Neon/Supabase/PgBouncer):
#   DATABASE_URL="postgresql://USER:PASS@HOST-pooler.region.aws.neon.tech/db?sslmode=require"
#   3. npm run db:push && node scripts/init-db.mjs

# ── Auth ───────────────────────────────────────────────────────────────────
# Set NODE_ENV=production in real deployments so the session cookie is Secure.

# ── Site ───────────────────────────────────────────────────────────────────
# Canonical URL used for metadata, robots.txt and sitemap.xml.
NEXT_PUBLIC_SITE_URL="https://gourmetgrove.example.com"

# ── Wire Payment (https://api.wirepayment.mn) ────────────────────────────────
# Leave BLANK to run payments in mock mode (auto-succeeds — great for demos).
# Set the live secret key to take real deposits via QPay.
WIRE_SECRET_KEY=""
# Webhook signing secret (whsec_…) from the dashboard, if you register a webhook.
WIRE_WEBHOOK_SECRET=""
