// GourmetGrove — Prisma schema (PostgreSQL — required for Vercel/serverless).
//
// Local dev: point DATABASE_URL at a Neon/Supabase/Postgres instance and run
//   `npm run db:setup` (prisma db push + scripts/init-db.mjs).
// SQLite is NOT used anymore because Vercel's filesystem is ephemeral/read-only.
//
// Double-booking is prevented by a PARTIAL UNIQUE INDEX on confirmed
// reservations (scripts/init-db.mjs) — atomic at the DB level under concurrency.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // optional: unpooled URL for migrations (Neon/Supabase)
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("USER") // USER | ADMIN
  createdAt    DateTime      @default(now())
  sessions     Session[]
  reservations Reservation[]
}

/// Admin-controlled per-dish availability override. Static dishes (lib/data.ts)
/// can be marked unavailable here; CustomDish (admin-added) live in their own table.
model DishAvailability {
  dishId    String   @id
  available Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

/// Admin-created dishes (not in the static catalog). Edited / removed freely.
model CustomDish {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  image       String
  calories    Int      @default(0)
  prepMinutes Int      @default(10)
  rating      Float    @default(4.7)
  available   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

/// Singleton — restaurant configuration. Row keyed `id = "default"`.
model RestaurantSettings {
  id              String   @id @default("default")
  venueName       String   @default("Xasu")
  venueAddress    String   @default("Ulaanbaatar, Mongolia")
  contactPhone    String   @default("")
  contactEmail    String   @default("")
  /// JSON: { mon: { open: "17:00", close: "23:00", closed: false }, ... }
  hours           Json
  /// Deposit per booking, in MNT
  depositMnt      Int      @default(20000)
  maxPartySize    Int      @default(12)
  /// JSON string[] — YYYY-MM-DD dates blacked out (holidays, private events)
  blackoutDates   Json
  /// Reservations only accepted up to N days ahead
  bookingWindow   Int      @default(60)
  updatedAt       DateTime @updatedAt
}

/// Restaurant table — once seeded from lib/data.ts, admin can fully manage.
model Table {
  id        String  @id
  label     String
  zone      String
  shape     String  // round | rect | square | booth
  seats     Int
  x         Float   // 0–100 grid
  y         Float
  rotation  Float   @default(0)
  position  String  // descriptive
  image     String
  pano      String?
  /// Permanently disabled (vs temporary status like cleaning)
  disabled  Boolean @default(false)
  /// Display order
  sortOrder Int     @default(0)
  updatedAt DateTime @updatedAt

  @@index([zone])
}

/// Append-only audit trail for admin actions. Diff stored as JSON.
model AuditEntry {
  id         String   @id @default(cuid())
  actorId    String
  actorName  String
  action     String   // e.g. "reservation.update", "settings.update"
  entity     String   // e.g. "reservation", "settings", "dish"
  entityId   String?
  /// JSON blob: { before: {...}, after: {...} }
  diff       Json
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([actorId])
}

model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

/// Food order placed from the cart (QR table ordering or remote online order).
/// Separate from Reservation — this is what the kitchen fulfils.
model Order {
  id              String   @id @default(cuid())
  /// null for guest/QR orders with no logged-in user
  userId          String?
  tableId         String
  /// JSON: [{ id, name, qty, unit }] — unit is MNT integer, priced server-side
  items           Json
  /// Totals in MNT (integer), all computed server-side
  subtotal        Int      @default(0)
  serviceFee      Int      @default(0)
  amount          Int      @default(0)
  /// new | preparing | served | completed | cancelled
  status          String   @default("new")
  paymentStatus   String   @default("unpaid") // unpaid | paid | refunded | failed
  paymentIntentId String?
  source          String   @default("qr") // qr | online
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
  @@index([tableId])
  @@index([status])
  @@index([paymentStatus])
}

/// Restaurant staff (separate from User accounts — these are physical employees
/// tracked by PIN, not necessarily app users).
model Employee {
  id         String   @id @default(cuid())
  name       String
  /// 4-6 digit PIN used at the clock-in terminal. Stored plain — low-risk
  /// and the terminal is operated under supervision.
  pin        String   @unique
  role       String   @default("staff") // staff | server | cook | manager
  /// Hourly wage in MNT (integer)
  hourlyRate Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shifts     Shift[]
  scheduled  ScheduledShift[]
}

/// One clock-in / clock-out pair. clockOut null while shift in progress.
model Shift {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockIn    DateTime
  clockOut   DateTime?
  note       String?
  createdAt  DateTime  @default(now())

  @@index([employeeId, clockIn])
}

/// Planned shift — admin can compare against actual Shift records.
model ScheduledShift {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       String   // YYYY-MM-DD
  startTime  String   // HH:mm
  endTime    String   // HH:mm
  notes      String?
  createdAt  DateTime @default(now())

  @@index([employeeId, date])
  @@index([date])
}

model Reservation {
  id        String   @id @default(cuid())
  /// null when an admin creates a walk-in / phone booking — guestName/Phone used instead.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// For walk-ins / phone bookings — name + phone are mandatory if userId is null.
  guestName  String?
  guestPhone String?
  tableId   String
  zone      String
  partySize Int
  date      String // YYYY-MM-DD
  time      String // HH:mm
  status    String   @default("CONFIRMED") // CONFIRMED | ARRIVED | COMPLETED | CANCELLED | NO_SHOW
  /// Where the booking came from — used in analytics and audit.
  source    String   @default("online") // online | walkin | phone | admin
  /// Free-form admin annotations: allergies, prefs, special occasions.
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Deposit payment (Wire) ──
  amount          Int     @default(0) // deposit in MNT (integer)
  paymentStatus   String  @default("unpaid") // unpaid | paid | refunded | failed
  paymentIntentId String?

  @@index([userId])
  @@index([guestPhone])
  @@index([tableId, date, time])
  @@index([date])
}
